# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=techmarket
DB_USERNAME=techmarket
DB_PASSWORD=techmarket_secret

# Redis / Dragonfly
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (Redpanda)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# JWT (must match across services)
JWT_SECRET=techmarket-dev-secret-key-change-in-production-min-32-chars!!

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=YourBotUsername

# Mail (Gmail SMTP — use App Password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Auth Service URL
AUTH_SERVICE_URL=http://localhost:8082
